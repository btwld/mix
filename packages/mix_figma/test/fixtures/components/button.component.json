{
  "schema": "mix_atlas/component/v2",
  "id": "button",
  "label": "Button",
  "properties": [
    { "id": "variant", "kind": "enum", "values": ["primary"], "required": true, "default": "primary" },
    { "id": "size", "kind": "enum", "values": ["md"], "required": true, "default": "md" },
    { "id": "label", "kind": "string", "required": true, "default": "Button" },
    { "id": "enabled", "kind": "boolean", "required": true, "default": true },
    { "id": "loading", "kind": "boolean", "required": true, "default": false }
  ],
  "states": [
    { "id": "default", "widgetStates": [], "properties": {} },
    { "id": "hovered", "widgetStates": ["hovered"], "properties": {} },
    { "id": "pressed", "widgetStates": ["pressed"], "properties": {} },
    { "id": "focused", "widgetStates": ["focused"], "properties": {} },
    { "id": "disabled", "widgetStates": ["disabled"], "properties": { "enabled": false } },
    { "id": "loading", "widgetStates": ["disabled"], "properties": { "enabled": false, "loading": true } }
  ],
  "slots": [
    { "id": "root", "kind": "flex_box" },
    { "id": "label", "kind": "text" }
  ],
  "anatomy": {
    "root": "root",
    "nodes": [
      { "id": "root", "kind": "flex_box", "slot": "root", "children": ["label"] },
      {
        "id": "label",
        "kind": "text",
        "slot": "label",
        "children": [],
        "bindings": { "text": { "property": "label" } }
      }
    ]
  },
  "recipes": [
    {
      "id": "primary-md",
      "properties": { "variant": "primary", "size": "md" },
      "styles": { "root": "primary-md/root", "label": "primary-md/label" }
    }
  ],
  "styles": {
    "primary-md/root": {
      "v": 1,
      "type": "flex_box",
      "direction": "horizontal",
      "mainAxisAlignment": "center",
      "crossAxisAlignment": "center",
      "spacing": 8,
      "padding": { "left": 16, "top": 10, "right": 16, "bottom": 10 },
      "decoration": { "color": "#336699", "borderRadius": 8 }
    },
    "primary-md/label": {
      "v": 1,
      "type": "text",
      "style": {
        "color": "#FFFFFF",
        "fontFamily": "Inter",
        "fontSize": 14,
        "fontWeight": "w600",
        "height": 1.4
      }
    }
  },
  "semantics": {
    "role": "button",
    "bindings": {
      "label": { "property": "label" },
      "enabled": { "property": "enabled" }
    }
  },
  "oracles": [],
  "diagnostics": []
}
