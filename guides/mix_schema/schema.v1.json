    "VariantArray_icon":     { "type": "array", "items": { "$ref": "#/$defs/Variant_icon"     }, "minItems": 1 },
    "VariantArray_image":    { "type": "array", "items": { "$ref": "#/$defs/Variant_image"    }, "minItems": 1 },
    "VariantArray_stack":    { "type": "array", "items": { "$ref": "#/$defs/Variant_stack"    }, "minItems": 1 },
    "VariantArray_flexbox":  { "type": "array", "items": { "$ref": "#/$defs/Variant_flexbox"  }, "minItems": 1 },
    "VariantArray_stackbox": { "type": "array", "items": { "$ref": "#/$defs/Variant_stackbox" }, "minItems": 1 },

    "Variant_box": {
      "description": "Variant on a Style_box. Decision #25: variant style MUST match enclosing spec.",
      "type": "object",
      "required": ["when", "style"],
      "additionalProperties": false,
      "properties": {
        "when":  { "$ref": "#/$defs/WhenExpr" },
        "style": { "$ref": "#/$defs/Style_box" }
      }
    },
    "Variant_flex": {
      "type": "object",
      "required": ["when", "style"],
      "additionalProperties": false,
      "properties": {
        "when":  { "$ref": "#/$defs/WhenExpr" },
        "style": { "$ref": "#/$defs/Style_flex" }
      }
    },
    "Variant_text": {
      "type": "object",
      "required": ["when", "style"],
      "additionalProperties": false,
      "properties": {
        "when":  { "$ref": "#/$defs/WhenExpr" },
        "style": { "$ref": "#/$defs/Style_text" }
      }
    },
    "Variant_icon": {
      "type": "object",
