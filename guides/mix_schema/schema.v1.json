    "AnimationNode": {
      "oneOf": [
        {
          "type": "object",
          "required": ["kind", "duration", "curve"],
          "additionalProperties": false,
          "properties": {
            "kind":     { "const": "curve" },
            "duration": { "type": "integer", "minimum": 0 },
            "curve":    { "$ref": "#/$defs/CurveName" },
            "delay":    { "type": "integer", "minimum": 0 }
          }
        },
        {
          "type": "object",
          "required": ["kind", "duration"],
          "additionalProperties": false,
          "properties": {
            "kind": {
              "enum": [
                "decelerate", "ease", "easeIn", "easeInSine",
                "easeInQuad", "easeInCubic", "easeInQuart", "easeInQuint",
                "easeInToLinear", "fastLinearToSlowEaseIn",
                "fastEaseInToSlowEaseOut"
              ]
            },
            "duration": { "type": "integer", "minimum": 0 },
            "delay":    { "type": "integer", "minimum": 0 }
          }
        }
      ]
    },

    "CurveName": {
      "type": "string",
      "description": "Named Flutter curve. Non-exhaustive; reference validator maintains the full list.",
      "enum": [
        "linear",
        "decelerate",
        "fastLinearToSlowEaseIn",
        "fastEaseInToSlowEaseOut",
        "ease", "easeIn", "easeInToLinear", "easeInSine", "easeInQuad",
        "easeInCubic", "easeInQuart", "easeInQuint", "easeInExpo", "easeInCirc", "easeInBack",
        "easeOut", "easeOutSine", "easeOutQuad", "easeOutCubic", "easeOutQuart",
        "easeOutQuint", "easeOutExpo", "easeOutCirc", "easeOutBack",
        "easeInOut", "easeInOutSine", "easeInOutQuad", "easeInOutCubic", "easeInOutQuart",
        "easeInOutQuint", "easeInOutExpo", "easeInOutCirc", "easeInOutBack",
        "bounceIn", "bounceOut", "bounceInOut",
        "elasticIn", "elasticOut", "elasticInOut"
      ]
    },

    "Literal_Icon": {
      "type": "object",
      "required": ["source"],
      "oneOf": [
        {
          "required": ["source", "name"],
          "additionalProperties": false,
          "properties": {
