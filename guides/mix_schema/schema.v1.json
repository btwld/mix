    "WhenExpr": {
      "oneOf": [
        { "$ref": "#/$defs/When_state" },
        { "$ref": "#/$defs/When_named" },
        { "$ref": "#/$defs/When_enum" },
        { "$ref": "#/$defs/When_context" },
        { "$ref": "#/$defs/When_not" },
        { "$ref": "#/$defs/When_Extension" }
      ]
    },

    "When_state": {
      "type": "string",
      "enum": [
        "onHovered", "onPressed", "onFocused", "onDisabled",
        "onEnabled", "onSelected", "onError",
        "onDark", "onLight"
      ]
    },

    "When_named": {
      "type": "object",
      "required": ["named"],
      "additionalProperties": false,
      "properties": {
        "named": { "type": "string", "minLength": 1 }
      }
    },

    "When_enum": {
      "type": "object",
      "required": ["enum"],
      "additionalProperties": false,
      "properties": {
        "enum": { "type": "string", "pattern": "^[A-Za-z_][A-Za-z0-9_]*\\.[A-Za-z_][A-Za-z0-9_]*$" }
      }
    },

    "When_context": {
      "oneOf": [
        {
          "type": "object",
          "required": ["context", "token"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "breakpoint" },
            "token":   { "type": "string", "pattern": "^breakpoint\\..+|^x:[a-z][a-z0-9_-]*\\..+" }
          }
        },
        {
          "type": "object",
          "required": ["context", "value"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "orientation" },
            "value":   { "enum": ["portrait", "landscape"] }
          }
        },
        {
          "type": "object",
          "required": ["context", "value"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "brightness" },
            "value":   { "enum": ["light", "dark"] }
          }
        },
        {
          "type": "object",
          "required": ["context", "value"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "platform" },
            "value":   { "enum": ["android", "iOS", "fuchsia", "linux", "macOS", "windows"] }
          }
        },
        {
          "type": "object",
          "required": ["context", "value"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "directionality" },
            "value":   { "enum": ["ltr", "rtl"] }
          }
        },
        {
          "type": "object",
          "required": ["context", "value"],
          "additionalProperties": false,
          "properties": {
            "context": { "const": "preset" },
            "value":   { "enum": ["mobile", "tablet", "desktop", "web"] }
          }
        }
      ]
    },

    "When_not": {
      "type": "object",
      "required": ["not"],
      "additionalProperties": false,
      "properties": {
        "not": { "$ref": "#/$defs/WhenExpr" }
      }
    },

    "When_Extension": {
      "type": "object",
      "description": "Custom when expression via x: key.",
      "minProperties": 1,
      "maxProperties": 1,
      "propertyNames": { "$ref": "#/$defs/ExtensionId" }
    },

