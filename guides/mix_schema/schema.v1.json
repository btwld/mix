      }
    },
    "Variant_flexbox": {
      "type": "object",
      "required": ["when", "style"],
      "additionalProperties": false,
      "properties": {
        "when":  { "$ref": "#/$defs/WhenExpr" },
        "style": { "$ref": "#/$defs/Style_flexbox" }
      }
    },
